# Configuración de VozIA Backend
# Copiar este archivo a .env y ajustar según necesidades

# ========== APLICACIÓN ==========
DEBUG=True
API_TITLE=VozIA API
API_VERSION=1.0.0

# ========== OPENAI (OPCIONAL) ==========
# OPENAI_API_KEY=sk-xxx

# ========== BASE DE DATOS ==========
DATABASE_URL=sqlite:///./vozia.db

# ========== CORS ==========
CORS_ORIGINS=["*"]

# ========== RUTAS ==========
UPLOAD_DIR=uploads
